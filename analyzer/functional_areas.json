      "AD_ALERTRULE", "AD_ALERT", "AD_PREFERENCE",
      "C_ACCTSCHEMA", "AD_SEQUENCE"
    ],
    "windows": [
      "%organization%", "%role%", "%user%", "%client%", "%alert%",
      "%preference%", "%general%setup%"
    ]
  }
}

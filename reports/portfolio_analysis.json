  "generalizable_customizations": [
    {
      "type": "core",
      "client": "MDF",
      "name": "Void Date para Facturas de Venta (DocAction + ProcessInvoice)",
      "description": "Extiende la logica de reversión de documentos para incluir las Facturas de Venta (ventana ID 167) en los controles de fecha de anulación. Antes, solo las Facturas de Compra y los Albaranes de Entrada mostraban los campos de fecha de anulación al revertir (acción RC). El parche añade `salesInvoiceWindow = '167'` a DocAction.html y la constante equivalente en ProcessInvoice.java.",
      "justification": "El comportamiento es simétrico con las Facturas de Compra y debería aplicar igualmente a las de Venta. Es una omisión del core de Etendo que afectaría a cualquier instalación con reversión de facturas de venta.",
      "effort_saas_hours": 2
    },
    {
      "type": "core",
      "client": "MDF",
      "name": "Tolerancia en recalculo de impuesto de línea de factura (C_INVOICELINE_TRG2)",
      "description": "Modifica el trigger de línea de factura para usar comparaciones con tolerancia (abs > 0.05) en lugar de igualdad estricta al determinar si recalcular los impuestos. Evita recalculos innecesarios causados por diferencias de redondeo en punto flotante. También añade un END IF faltante en el cuerpo del trigger.",
      "justification": "La comparación estricta de igualdad en cálculos de importe puede causar recalculos erróneos por redondeo. La tolerancia de 0.05 es una corrección pragmática que beneficiaría a todas las instalaciones con IVA incluido. El END IF faltante es un bug real.",
      "effort_saas_hours": 1
    },
